# YouTube Data API v3 key — required
# https://console.developers.google.com/ → create project → enable YouTube Data API v3
YOUTUBE_API_KEY=

# NewsAPI key — currently unused but kept for future news shelf feature
NEWS_API_KEY=

# VK user access token with `video` scope — optional
# Without it, the "VK · RuTube" source shows only RuTube videos.
# To obtain: vkhost.github.io → choose "Kate Mobile" → authorize → copy access_token from URL
VK_ACCESS_TOKEN=
